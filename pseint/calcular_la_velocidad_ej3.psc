Algoritmo calcular_la_velocidad_ej3
	//definir variables
	Definir velocidad, tiempo, distancia Como Real;
	//entrada de datos
	Escribir "ingrese la distancia recorrida; ";
	Leer distancia;
	Escribir "ingrese el tiempo trancurrido: ";
	
	Leer tiempo;
	//Proceso 
	//conociendo que la velocidad es igual a distancia entre tiempo
	velocidad <- distancia/tiempo;
	//salida de datos
	Mostrar "la velocidad del viaje es: ",velocidad, "m/s";
FinAlgoritmo
